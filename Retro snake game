#include <iostream>//Standardno zaglavlje za cpp biblioteku
#include <raylib.h>//Zaglavlje za raylib biblioteku
#include <deque>//Zaglavlje za strukturu podataka dek
#include <raymath.h>//Zaglavlje za matematicku biblioteku

using namespace std;//Rezervisanje korisnickog prostora

int velicina_celije=30;//Deklarisanje velicine celije
int broj_celija=25;//Deklarisanje kolicine celija
int ofset=75;//Deklarisanje ofseta
double poslednj_update=0;//Deklarisanje poslednjeg azuriranja

Color zelena={173,204,96, 255}; //deklarises boje po RGB-alpha sistemu  -  pozadia
Color tamno_zelena={43,51,24, 255}; // zmija

bool Element_u_dequ(Vector2 element, deque<Vector2> dek)
{
    for (unsigned int i = 0; i <dek.size(); i++)
    {
        if (Vector2Equals(dek[i], element))
        {
            return true;
        }
    }
    return false;
}

bool eventTriggered(double interval)
{
    double trenutno_vreme = GetTime();

    if (trenutno_vreme-poslednj_update>=interval)
    {
        poslednj_update=trenutno_vreme;
        return true;
    }
    return false;
}

class Zmija//Deklarisanje klase Zmija
{
    public://Deklarisanje javnih promenljivih
    deque<Vector2> telo={Vector2{6,9},Vector2{5,9},Vector2{4,9}};//Deklarisanje deka za telo zmije u kojem je svaki clan vektor sa 2 kordinate x i y
    Vector2 direkcija={1,0};//Deklarisanje vektora za promenu direkcije
    bool dodaj_segment=false;//Deklarisanje bool promenljive za proveru tokom dodavanja segmenata zmije

    void Crtaj()//Deklarisanje metode za crtanje tela
    {
        for (unsigned int i = 0; i < telo.size(); i++)//Deklarisanje for petlje za crtanje svih delova tela pojedinacno
        {
            float x = telo[i].x;//Deklarisanje x koordinate iz trenutnog dela tela
            float y = telo[i].y;//Deklarisanje y koordinate iz trenutnog dela tela
            Rectangle segment=Rectangle{ofset+x*velicina_celije,ofset+y*velicina_celije,(float)velicina_celije,(float)velicina_celije};//Deklarisanje promenljive segmet tipa Pravougaonik i dodeljivanje karakteristika istom
            DrawRectangleRounded(segment,0.5,6,tamno_zelena);//Crtanje malopre deklarisanog segmenta sa zaobljenim ivicama i tamno zelenom bojom
        }
    }

    void Update()//Deklarisanje metode koja se ponavlja svaki put kada se zmija pomeri
    {
        telo.push_front(Vector2Add(telo[0],direkcija));//Dodavanje dela tela na pocetak zmije
        if (dodaj_segment==true)//Provera da li je segment vec dodat ako nije promenljiva dodaj_segment promenljiva ostaje na true, a ako jeste stavlja se na false
        {
           dodaj_segment=false;
        }
        else
        {
            telo.pop_back();//Uklanjanje zadnjeg dela tela
        }
    }

    void Reset()//Deklarisanje metode za postavljanje zmijice i smera kretanja na pocetno mesto
    {
        telo={Vector2{6,9},Vector2{5,9},Vector2{4,9}};
        direkcija={1,0};
    }
};

class Jabuka//Deklaracija klase jabuka
{
    public:
        Vector2 pozijcia={0,0};//deklarisana pozicija jabuke na ekranu
        Texture2D textrua;//izgled jabuke se stavlja u ovu promenljivu
        
        Jabuka(deque<Vector2> telo_zmije)// pravimo osnovni konstruktor koji sadrzi opis nase jabuke
        {
            Image slika = LoadImage("Grafika/jabuka.png");// pravimo promenljivu tipa image i dajemo joj vrednost nase slike jabuke
            textrua=LoadTextureFromImage(slika);// teksturi dajemo izgled po nasoj slici 
            UnloadImage(slika);//brisemo sliku iz memorije kako ne bi zauzimali previse memorje 
            pozijcia=Generisi_Poziciju(telo_zmije);// pozivamo metodu za generisanje nasumicne pozicije jabuke na ekranu
        }
        
        ~Jabuka()//destruktor, brise sve sto nam ne treba kada se objekat vise ne koristi
        {
            UnloadTexture(textrua);
        }
        
        void Crtaj()//crtamo nasu jabuku na ekranu
        {
            DrawTexture(textrua,ofset+pozijcia.x*velicina_celije, ofset+pozijcia.y*velicina_celije, WHITE);
        }
        
        Vector2 Generisi_celiju()//Deklarisanje metode za pravljenje celije sa nasumicnim mestom na ekranu
        {
            float x= GetRandomValue(0,broj_celija-1);//Deklarisanje x koordinate pomocu radnom metode za generisanje x koordinate
            float y= GetRandomValue(0,broj_celija-1);
            return Vector2{x,y};//vracanje generisane celije
        }

        Vector2 Generisi_Poziciju(deque<Vector2> telo_zmije)// metoda za generisanje nasumicnih pozicija
        {
            Vector2 pozijcia=Generisi_celiju();//Deklarisanje pozicije i pozivanje metode generisi celiju
            while (Element_u_dequ(pozijcia,telo_zmije))//Provera da li je celija generisana na telu zmije, ako jeste ponvo se generise
            {
               pozijcia= Generisi_celiju();
            }   
            return pozijcia;//vracanje celije 
        }

};

class Igra//Deklarisanje klase igre
{
    public:
        Zmija zmija = Zmija(); //Pravljenje objekta zmije na osnovu klase zmije
        Jabuka jabuka = Jabuka(zmija.telo); 
        bool ide=true; //Promenljiva za kretanje zmije
        int score=0;//Deklaracija za broj bodova pojedenih jabuka
    void Iscrtaj()//Pozivam obe metode
    {
        jabuka.Crtaj();
        zmija.Crtaj();
    }
    void Updata()
    {
        if (ide)
        {
            zmija.Update();
            Provera_jedenja();
            Proveri_dodir_sa_zidom();
            Proveri_dodir_sa_telom();
        }
   
    }
    void Provera_jedenja()//Metoda za proveru jedenja 
    {
        if (Vector2Equals(zmija.telo[0],jabuka.pozijcia))//Ako su pozicija glave zmije i pozicija jabuke jednake jabuci se generise nova pozicija a zmiji se dodaje jedan segmenat
        {
            jabuka.pozijcia=jabuka.Generisi_Poziciju(zmija.telo);
            zmija.dodaj_segment=true;
            score++;//Povecava se broj bodova
        }
    }
    void Proveri_dodir_sa_zidom()//Metoda proverava da li je zmija dodirnula zid
    {
        if (zmija.telo[0].x==broj_celija || zmija.telo[0].x== -1)//Proveravamo da li glava zmije dodirnula krajeve zidova na x osi
        {
           Kraj_Igre();//Poziva se metoda za kraj igre
        }
        if (zmija.telo[0].y==broj_celija || zmija.telo[0].y== -1)
        {
           Kraj_Igre();
        }
    }
    void Proveri_dodir_sa_telom()
    {
        deque<Vector2> telo_bez_glave=zmija.telo;
        telo_bez_glave.pop_front();
        if (Element_u_dequ(zmija.telo[0],telo_bez_glave))
        {
            Kraj_Igre();
        }
    }
    void Kraj_Igre()
    {
       zmija.Reset();
       jabuka.pozijcia=jabuka.Generisi_Poziciju(zmija.telo);
       ide=false;
       score=0;
    }
};

int main () {

    cout << "Zapocni igru..." << endl;
    
    InitWindow(2*ofset+velicina_celije*broj_celija,2*ofset+velicina_celije*broj_celija,"Retro Zmijica");//pravljenje prozoraa u kojem je igrica, i dodeljivanje naslova i velicine (x,y,naslov
    SetTargetFPS(60);//frame rate (Bitan za brzinu igre )

    Igra igra= Igra();
    //LOOP
    while (WindowShouldClose()==false) // Game loop (Event lisneri, Crtanje objekata(zmije i voca...), Pomeranje Objekata)
    {
        BeginDrawing();

        if (eventTriggered(0.2))
        {
            igra.Updata();
        }
        if ((IsKeyPressed(KEY_W) || IsKeyPressed(KEY_UP))&& igra.zmija.direkcija.y!=1)
        {
            igra.zmija.direkcija={0,-1};
            igra.ide=true;
        }
        if ((IsKeyPressed(KEY_S) || IsKeyPressed(KEY_DOWN))&& igra.zmija.direkcija.y!=-1)
        {
            igra.zmija.direkcija={0,1};
            igra.ide=true;
        }
        if ((IsKeyPressed(KEY_A) || IsKeyPressed(KEY_LEFT) )&& igra.zmija.direkcija.x!=1)
        {
            igra.zmija.direkcija={-1,0};
            igra.ide=true;
        }
        if ((IsKeyPressed(KEY_D) || IsKeyPressed(KEY_RIGHT)) && igra.zmija.direkcija.x!=-1)
        {
            igra.zmija.direkcija={1,0};
            igra.ide=true;
        }

        ClearBackground(zelena);// ocisti ekran i ofarba ga u zadatu boju(zelenu)
        DrawRectangleLinesEx(Rectangle{(float)ofset-5 , (float)ofset-5 , (float)broj_celija*velicina_celije+10 , (float)broj_celija*velicina_celije+10},5,tamno_zelena);
        DrawText("Retro zmija", ofset-5,20,40,tamno_zelena);
        DrawText(TextFormat("%i",igra.score),velicina_celije*broj_celija+10,20,40,tamno_zelena);
        igra.Iscrtaj();

        EndDrawing();
    }
    CloseWindow();
    return 0;
}
